node_name                     = "pve-node01"
datastore_disk                = "local-vm"
network_bridge                = "vmbr0"
virtual_environment_endpoint  = "https://192.168.1.100:8006/api2/json"
virtual_environment_api_token = "XXXXXXXXXXXXXXXXXXXXXX"
ubuntu_cloud_image_url        = "https://cloud-images.ubuntu.com/minimal/daily/noble/current/noble-minimal-cloudimg-amd64.img"
agent_enabled                 = true
vm_reboot                     = false
tailscale_authkey             = "tskey-auth-XXXXXXX"
default_username              = "ubuntu"
default_cloud_init            = "user-data.yaml"
default_cpu_type              = "x86-64-v2-AES"
default_hotplug_cpu           = false
default_hotplug_memory        = false
default_max_cpu               = 4
default_max_memory            = 8192
default_machine_type          = "i440fx"               # Default machine type
default_viommu                = ""                     # No vIOMMU by default

vms = {
  web1 = {
    name       = "web-server-01"
    vm_id      = 5500
    cpu_cores  = 2
    memory     = 4096
    disk_size  = 40
    vlan_id    = 102
    username   = "webadmin"
    tags       = ["web", "production"]
  },
  web2 = {
    name       = "web-server-02"
    vm_id      = 5501
    cpu_cores  = 2
    memory     = 4096
    disk_size  = 40
    vlan_id    = 102
    username   = "webadmin"
    cpu_type   = "host"  # Use the host CPU type for maximum performance
    cloud_init_template = "user-data2.yaml"  # Use the version without ASCII logo
    tags       = ["web", "production"]
  },
  db = {
    name       = "database-01"
    vm_id      = 5502
    cpu_cores  = 4
    memory     = 8192
    disk_size  = 100
    vlan_id    = 103
    username   = "dbadmin"
    vm_reboot  = true  # This VM will reboot after creation
    cloud_init_template = "db-init.yaml"  # Using the database-specific cloud-init template
    tags       = ["database", "production"]
  },
  dev = {
    name       = "dev-server"
    vm_id      = 5503
    cpu_cores  = 1
    memory     = 2048
    disk_size  = 20
    vlan_id    = 104
    username   = "devuser"
    tags       = ["development"]
  },
  test = {
    name       = "test-server"
    vm_id      = 5504
    cpu_cores  = 1
    memory     = 2048
    disk_size  = 20
    vlan_id    = 104
    # No username specified - will use the default_username
    tags       = ["testing"]
  },
  scaling = {
    name             = "scaling-server"
    vm_id            = 5505
    cpu_cores        = 2             # Initial CPU cores
    memory           = 4096          # Initial memory
    disk_size        = 40
    vlan_id          = 102
    username         = "scalingadmin"
    cloud_init_template = "hotplug-enabled.yaml"  # Using the hotplug-enabled template
    hotplug_cpu      = true          # Enable CPU hotplug
    hotplug_memory   = true          # Enable memory hotplug
    max_cpu          = 8             # Maximum CPUs that can be assigned
    max_memory       = 16384         # Maximum memory that can be assigned (16GB)
    tags             = ["scalable", "production"]
  },
  nested_vm = {
    name             = "nested-hypervisor"
    vm_id            = 5506
    cpu_cores        = 4
    memory           = 8192
    disk_size        = 60
    vlan_id          = 102
    username         = "nestedadmin"
    cloud_init_template = "viommu-enabled.yaml"  # Using the vIOMMU-enabled template
    machine_type     = "q35"         # Required for Intel vIOMMU
    viommu           = "intel"       # Enable Intel vIOMMU
    cpu_type         = "host"        # Use host CPU type for best nested virtualization performance
    tags             = ["nested", "development"]
  }
}